{
  "name": "Kali Linux Cyber Security Basics",
  // Two containers are started from docker-compose.yml: the Kali "workspace"
  // students work in, and a self-contained DVWA vulnerable web app reachable
  // at http://dvwa for safe, offline web-recon practice.
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/Learn_Kali-Linux-Basics",
  "remoteUser": "student",
  "hostRequirements": {
    "cpus": 2
  },
  // Open the DVWA web UI in a browser tab on http://localhost:4280
  "forwardPorts": [4280],
  "portsAttributes": {
    "4280": {
      "label": "DVWA (vulnerable web app)",
      "onAutoForward": "silent"
    }
  },
  "waitFor": "onCreateCommand",
  "updateContentCommand": "",
  "postCreateCommand": "pip3 install --break-system-packages -r requirements.txt || pip3 install -r requirements.txt",
  "postStartCommand": "",
  "customizations": {
    "vscode": {
      "settings": {
        "files.autoSave": "onFocusChange",
        "editor.fontSize": 18,
        "extensions.ignoreRecommendations": true,
        "window.restoreWindows": "preserve",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "workbench.colorTheme": "Default Dark+",
        "workbench.iconTheme": "vscode-icons",
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "chat.agent.enabled": true
      },
      "extensions": [
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "saeris.markdown-github-alerts",
        "esbenp.prettier-vscode",
        "GitHub.codespaces",
        "mathematic.vscode-pdf",
        "mechatroner.rainbow-csv",
        "ms-python.python",
        "ms-python.debugpy",
        "oderwat.indent-rainbow",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-british-english",
        "yusifaliyevpro.vscicons",
        "timonwong.shellcheck",
        "foxundermoon.shell-format"
      ]
    }
  }
}
